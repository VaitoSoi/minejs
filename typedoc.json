{
    "$schema": "https://typedoc.org/schema.json",
    "entryPoints": [
        "src/index.ts"
    ],
    "tsconfig": "tsconfig.json",
    "readme": "README.md",
    "plugin": [
        "@clean-jsdoc-theme/typedoc"
    ],
    "outputs": [
        {
            "name": "clean-jsdoc-theme",
            "path": "docs_dist"
        }
    ],
    "cleanJsdocTheme": {
        "siteName": "MineJS"
    }
}